# Runtime-only image built from a verified Linux x64 release staging directory.
# The build context must contain bin/, config/, and manifest.json.
FROM ubuntu@sha256:4fbb8e6a8395de5a7550b33509421a2bafbc0aab6c06ba2cef9ebffbc7092d90

ARG SERVICE_BINARY
ARG RELEASE_TAG
ARG RELEASE_REVISION
ARG RELEASE_ASSET_SHA256
ARG RELEASE_CONFIG_SHA256

LABEL org.opencontainers.image.title="BoostGateway Backend" \
      org.opencontainers.image.source="https://github.com/HoneyBury/boost_gateway" \
      org.opencontainers.image.version="${RELEASE_TAG}" \
      org.opencontainers.image.revision="${RELEASE_REVISION}" \
      io.boost-gateway.release.asset.sha256="${RELEASE_ASSET_SHA256}" \
      io.boost-gateway.release.config.sha256="${RELEASE_CONFIG_SHA256}"

ENV LANG=C.UTF-8 \
    LC_ALL=C.UTF-8

WORKDIR /app

COPY bin/${SERVICE_BINARY} /app/bin/backend
COPY config/ /app/config/
COPY manifest.json /app/release-manifest.json

HEALTHCHECK --interval=10s --timeout=3s --retries=3 --start-period=5s \
    CMD timeout 2 bash -c '</dev/tcp/127.0.0.1/${SERVICE_PORT}' || exit 1

ENTRYPOINT ["/app/bin/backend"]
