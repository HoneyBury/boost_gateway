{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boost-gateway.local/schemas/backend-service.schema.json",
  "title": "Boost Gateway Backend Service Config",
  "type": "object",
  "additionalProperties": true,
  "required": ["service"],
  "properties": {
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "port", "config_version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "config_version": { "type": "string", "minLength": 1 }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "type": "string", "enum": ["dev", "external-jwt", "production", "prod", "jwt"] },
        "jwt_secret": { "type": "string" },
        "jwt_public_key_pem": { "type": "string" },
        "jwt_private_key_pem": { "type": "string" },
        "jwt_key_ring": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "jwks_uri": { "type": "string", "format": "uri" },
        "jwks_allowed_hosts": { "type": "string", "minLength": 1 },
        "jwks_allow_loopback_http": { "type": "boolean", "default": false },
        "jwks_connect_timeout_ms": { "type": "integer", "minimum": 1, "maximum": 10000 },
        "jwks_read_timeout_ms": { "type": "integer", "minimum": 1, "maximum": 10000 },
        "jwks_ttl_ms": { "type": "integer", "minimum": 1000 },
        "jwks_stale_grace_ms": { "type": "integer", "minimum": 0 },
        "jwks_minimum_refresh_interval_ms": { "type": "integer", "minimum": 0 },
        "jwks_max_response_bytes": { "type": "integer", "minimum": 1024, "maximum": 16777216 },
        "jwks_max_keys": { "type": "integer", "minimum": 1, "maximum": 128 },
        "jwt_issuer": { "type": "string" },
        "jwt_audience": { "type": "string" }
      }
    },
    "redis": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "password": { "type": "string" },
        "leaderboard_key": { "type": "string", "minLength": 1 }
      }
    },
    "raft": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "node_id": { "type": "string" },
        "storage_dir": { "type": "string" },
        "election_timeout_min_ms": { "type": "integer", "minimum": 1 },
        "election_timeout_max_ms": { "type": "integer", "minimum": 1 },
        "heartbeat_interval_ms": { "type": "integer", "minimum": 1 },
        "protobuf_writer_enabled": { "type": "boolean", "default": false },
        "peers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "host", "port"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "host": { "type": "string", "minLength": 1 },
              "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
            }
          }
        }
      }
    },
    "battle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_frames": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
