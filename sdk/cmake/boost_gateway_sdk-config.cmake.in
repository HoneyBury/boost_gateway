@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

if(NOT TARGET boost_gateway::nlohmann_json)
    add_library(boost_gateway::nlohmann_json INTERFACE IMPORTED)
    set_target_properties(boost_gateway::nlohmann_json PROPERTIES
        INTERFACE_INCLUDE_DIRECTORIES "${PACKAGE_PREFIX_DIR}/include")
endif()
if(NOT TARGET nlohmann_json::nlohmann_json)
    add_library(nlohmann_json::nlohmann_json ALIAS boost_gateway::nlohmann_json)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/boost_gateway_sdk-targets.cmake")

set(BoostGatewaySdk_VERSION "@BOOST_GATEWAY_SDK_VERSION@")
set(BoostGatewaySdk_VERSION_MAJOR "@BOOST_GATEWAY_SDK_VERSION_MAJOR@")
set(BoostGatewaySdk_VERSION_MINOR "@BOOST_GATEWAY_SDK_VERSION_MINOR@")
set(BoostGatewaySdk_VERSION_PATCH "@BOOST_GATEWAY_SDK_VERSION_PATCH@")

# Re-create the build-tree ALIAS for consumer convenience.
if(NOT TARGET boost_gateway::sdk)
    add_library(boost_gateway::sdk ALIAS boost_gateway::boost_gateway_sdk)
endif()

check_required_components(boost_gateway_sdk)
