{
  "__inputs": [],
  "__requires": [],
  "title": "Boost Gateway Production",
  "uid": "boost-gateway-production",
  "version": 2,
  "schemaVersion": 39,
  "tags": ["boost-gateway", "game-server", "production"],
  "timezone": "utc",
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "type": "datasource",
          "name": "Prometheus"
        },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "title": "Gateway Up",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 0 },
      "targets": [
        { "expr": "up{job=\"gateway\"}", "legendFormat": "gateway" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "description": "Prometheus scrape status for gateway /metrics"
    },
    {
      "title": "Active Sessions",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 5, "x": 4, "y": 0 },
      "targets": [
        { "expr": "gateway_active_sessions", "legendFormat": "active" }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 10000,
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 7000 },
              { "color": "red", "value": 9000 }
            ]
          }
        }
      },
      "description": "Current active gateway TCP sessions"
    },
    {
      "title": "Accepted Sessions",
      "type": "timeseries",
      "gridPos": { "h": 5, "w": 7, "x": 9, "y": 0 },
      "targets": [
        { "expr": "rate(gateway_accepted_sessions_total[1m])", "legendFormat": "accepted/s" },
        { "expr": "rate(gateway_sessions_accepted_total[1m])", "legendFormat": "accepted/s legacy server" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "description": "Accepted session rate. The v2 demo exports gateway_accepted_sessions_total; legacy server exports gateway_sessions_accepted_total."
    },
    {
      "title": "Outbound Dispatches",
      "type": "timeseries",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 0 },
      "targets": [
        { "expr": "rate(gateway_outbound_dispatches_total[1m])", "legendFormat": "dispatches/s" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "description": "Responses and pushes dispatched by the v2 gateway runtime"
    },
    {
      "title": "Gateway Packets",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 5 },
      "targets": [
        { "expr": "rate(gateway_packets_received_total[1m])", "legendFormat": "received/s" },
        { "expr": "rate(gateway_packets_sent_total[1m])", "legendFormat": "sent/s" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "pps" }
      },
      "description": "Packet counters exposed by the game gateway runtime when using the legacy GatewayServer metrics surface"
    },
    {
      "title": "Rate Limit / Blocked Packets",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 5 },
      "targets": [
        { "expr": "rate(gateway_packets_blocked_total[5m])", "legendFormat": "blocked/s" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "eps" }
      },
      "description": "Packets blocked by gateway protection controls"
    },
    {
      "title": "Backend Requests",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 5 },
      "targets": [
        { "expr": "sum by (__name__) (rate({__name__=~\"gateway_backend_.*_requests_total\"}[1m]))", "legendFormat": "{{__name__}}" },
        { "expr": "sum by (__name__) (rate({__name__=~\"gateway_backend_.*_successes_total\"}[1m]))", "legendFormat": "{{__name__}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "rps" }
      },
      "description": "Gateway-observed backend request and success rates"
    },
    {
      "title": "Backend Errors / Timeouts",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 11 },
      "targets": [
        { "expr": "sum by (__name__) (rate({__name__=~\"gateway_backend_.*_errors_total\"}[5m]))", "legendFormat": "{{__name__}}" },
        { "expr": "sum by (__name__) (rate({__name__=~\"gateway_backend_.*_timeouts_total\"}[5m]))", "legendFormat": "{{__name__}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "eps" }
      },
      "description": "Gateway RED counters for backend route errors and timeouts"
    },
    {
      "title": "Leaderboard / Redis Dependent Errors",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 11 },
      "targets": [
        { "expr": "rate(gateway_backend_leaderboard_errors_total[5m])", "legendFormat": "leaderboard errors/s" },
        { "expr": "rate(gateway_backend_leaderboard_timeouts_total[5m])", "legendFormat": "leaderboard timeouts/s" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "eps" }
      },
      "description": "Current Redis degradation signal is inferred through leaderboard backend route failures"
    },
    {
      "title": "Gateway Bytes",
      "type": "timeseries",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 17 },
      "targets": [
        { "expr": "rate(gateway_bytes_received_total[1m])", "legendFormat": "received B/s" },
        { "expr": "rate(gateway_bytes_sent_total[1m])", "legendFormat": "sent B/s" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      },
      "description": "Gateway payload byte rates when using the legacy GatewayServer metrics surface"
    },
    {
      "title": "Authenticated Sessions / Rooms / Battles",
      "type": "stat",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 17 },
      "targets": [
        { "expr": "gateway_authenticated_sessions", "legendFormat": "authenticated" },
        { "expr": "gateway_active_rooms", "legendFormat": "rooms" },
        { "expr": "gateway_active_battles", "legendFormat": "battles" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "description": "Business state gauges exposed by the game gateway runtime when present"
    },
    {
      "title": "Optional Process Exporter",
      "type": "timeseries",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 17 },
      "targets": [
        { "expr": "process_resident_memory_bytes{job=\"gateway\"}", "legendFormat": "rss" },
        { "expr": "process_open_fds{job=\"gateway\"}", "legendFormat": "open fds" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "description": "Optional process exporter metrics. Empty until a process exporter target is added."
    }
  ]
}
