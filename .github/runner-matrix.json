{
  "schema_version": 3,
  "description": "Versioned workflow runner matrix. Mainline CI may default to GitHub-hosted ubuntu-latest. Platform-aware production workflows select a native runner from their platform map unless an explicit runner input is supplied; legacy single-platform workflows may still use vars.XXX_RUNNER overrides.",
  "default_runner": "[\"self-hosted\",\"Linux\",\"X64\"]",
  "workflows": {
    "ci": {
      "enabled": true,
      "runner": "\"ubuntu-latest\"",
      "labels": { "os": "linux", "arch": "x64", "mode": "github-hosted-fallback" },
      "capabilities": { "github_hosted_fallback": true },
      "vars_hint": "CI_RUNNER"
    },
    "release": {
      "enabled": true,
      "runner": "[\"self-hosted\",\"Linux\",\"X64\"]",
      "labels": { "os": "linux", "arch": "x64" },
      "capabilities": {},
      "platforms": {
        "linux-x64": "[\"self-hosted\",\"Linux\",\"X64\",\"node-aoi-omen-gaming-laptop-16-am0xxx\"]",
        "linux-arm64": "[\"self-hosted\",\"Linux\",\"ARM64\",\"node-honeybury-m4-linux-arm64\"]",
        "macos-arm64": "[\"self-hosted\",\"macOS\",\"ARM64\",\"macos-arm64-candidate\"]"
      },
      "vars_hint": "RELEASE_RUNNER"
    },
    "release-asset-verification": {
      "enabled": true,
      "runner": "[\"self-hosted\",\"Linux\",\"X64\"]",
      "labels": { "os": "linux", "arch": "x64", "mode": "published-asset-verification" },
      "capabilities": { "docker": true },
      "platforms": {
        "linux-x64": "[\"self-hosted\",\"Linux\",\"X64\",\"node-aoi-omen-gaming-laptop-16-am0xxx\"]",
        "linux-arm64": "[\"self-hosted\",\"Linux\",\"ARM64\",\"node-honeybury-m4-linux-arm64\"]",
        "macos-arm64": "[\"self-hosted\",\"macOS\",\"ARM64\",\"macos-arm64-candidate\"]"
      },
      "vars_hint": "RELEASE_ASSET_VERIFICATION_RUNNER"
    },
    "perf-regression": {
      "enabled": true,
      "runner": "[\"self-hosted\",\"Linux\",\"X64\"]",
      "labels": { "os": "linux", "arch": "x64" },
      "capabilities": {},
      "platforms": {
        "linux-x64": "[\"self-hosted\",\"Linux\",\"X64\",\"node-aoi-omen-gaming-laptop-16-am0xxx\"]",
        "linux-arm64": "[\"self-hosted\",\"Linux\",\"ARM64\",\"node-honeybury-m4-linux-arm64\"]",
        "macos-arm64": "[\"self-hosted\",\"macOS\",\"ARM64\",\"macos-arm64-candidate\"]"
      },
      "vars_hint": "PERF_REGRESSION_RUNNER"
    },
    "nightly-stability": {
      "enabled": true,
      "runner": "[\"self-hosted\",\"Linux\",\"X64\"]",
      "labels": { "os": "linux", "arch": "x64" },
      "capabilities": {},
      "vars_hint": "NIGHTLY_RUNNER"
    },
    "conan-validate": {
      "enabled": true,
      "runner": "[\"self-hosted\",\"Linux\",\"X64\"]",
      "labels": { "os": "linux", "arch": "x64" },
      "capabilities": {},
      "vars_hint": "CONAN_VALIDATE_RUNNER"
    },
    "grpc-experimental": {
      "enabled": true,
      "runner": "[\"self-hosted\",\"Linux\",\"X64\"]",
      "labels": { "os": "linux", "arch": "x64" },
      "capabilities": { "loopback_bind": true },
      "vars_hint": "GRPC_EXPERIMENTAL_RUNNER"
    },
    "jwks-rotation": {
      "enabled": true,
      "runner": "[\"self-hosted\",\"Linux\",\"X64\"]",
      "labels": { "os": "linux", "arch": "x64", "mode": "identity-security-evidence" },
      "capabilities": { "loopback_bind": true, "openssl": true, "trusted_ephemeral_ca": true },
      "vars_hint": "JWKS_ROTATION_RUNNER"
    },
    "production-gates": {
      "enabled": true,
      "runner": "[\"self-hosted\",\"Linux\",\"X64\"]",
      "labels": { "os": "linux", "arch": "x64" },
      "capabilities": { "redis": true, "kind": true, "large_disk": true },
      "platforms": {
        "linux-x64": "[\"self-hosted\",\"Linux\",\"X64\"]",
        "linux-arm64": "[\"self-hosted\",\"Linux\",\"ARM64\",\"node-honeybury-m4-linux-arm64\"]",
        "macos-arm64": "[\"self-hosted\",\"macOS\",\"ARM64\",\"macos-arm64-candidate\"]"
      },
      "vars_hint": "PRODUCTION_GATES_RUNNER"
    },
    "production-candidate-evidence": {
      "enabled": true,
      "runner": "[\"self-hosted\",\"Linux\",\"X64\"]",
      "labels": { "os": "linux", "arch": "x64" },
      "capabilities": { "redis": true, "kind": true, "large_disk": true },
      "platforms": {
        "linux-x64": "[\"self-hosted\",\"Linux\",\"X64\"]",
        "linux-arm64": "[\"self-hosted\",\"Linux\",\"ARM64\",\"node-honeybury-m4-linux-arm64\"]",
        "macos-arm64": "[\"self-hosted\",\"macOS\",\"ARM64\",\"macos-arm64-candidate\"]"
      },
      "vars_hint": "PRODUCTION_CANDIDATE_RUNNER"
    },
    "preprod-evidence": {
      "enabled": true,
      "runner": "[\"self-hosted\",\"Linux\",\"X64\"]",
      "labels": { "os": "linux", "arch": "x64" },
      "capabilities": { "docker": true, "redis": true },
      "platforms": {
        "linux-x64": "[\"self-hosted\",\"Linux\",\"X64\",\"node-aoi-omen-gaming-laptop-16-am0xxx\"]",
        "linux-arm64": "[\"self-hosted\",\"Linux\",\"ARM64\",\"node-honeybury-m4-linux-arm64\"]",
        "macos-arm64": "[\"self-hosted\",\"macOS\",\"ARM64\",\"macos-arm64-candidate\"]"
      },
      "platform_producers": { "macos-arm64": "macos-arm64.yml native R5/R6" },
      "vars_hint": "PREPROD_EVIDENCE_RUNNER"
    },
    "production-readiness": {
      "enabled": true,
      "runner": "\"ubuntu-latest\"",
      "labels": { "os": "linux", "arch": "x64", "mode": "artifact-aggregation" },
      "capabilities": { "github_hosted_fallback": true },
      "target_platforms": ["linux-x64", "linux-arm64", "macos-arm64"],
      "vars_hint": "PRODUCTION_READINESS_RUNNER"
    },
    "long-soak-capacity": {
      "enabled": true,
      "runner": "[\"self-hosted\",\"Linux\",\"X64\"]",
      "labels": { "os": "linux", "arch": "x64" },
      "capabilities": { "redis": true, "large_disk": true, "dedicated": true },
      "platforms": {
        "linux-x64": "[\"self-hosted\",\"Linux\",\"X64\"]",
        "linux-arm64": "[\"self-hosted\",\"Linux\",\"ARM64\",\"node-honeybury-m4-linux-arm64\"]",
        "macos-arm64": "[\"self-hosted\",\"macOS\",\"ARM64\",\"macos-arm64-candidate\"]"
      },
      "vars_hint": "LONG_SOAK_CAPACITY_RUNNER"
    },
    "specialized-e2e": {
      "enabled": true,
      "runner": "[\"self-hosted\",\"Linux\",\"X64\"]",
      "labels": { "os": "linux", "arch": "x64" },
      "capabilities": { "redis": true, "kind": true },
      "vars_hint": "SPECIALIZED_E2E_RUNNER"
    },
    "macos-arm64": {
      "enabled": true,
      "runner": "[\"self-hosted\",\"macOS\",\"ARM64\"]",
      "labels": { "os": "macos", "arch": "arm64", "mode": "production-candidate" },
      "capabilities": { "native_arm64": true, "native_r5": true, "capacity_baseline_pending": true },
      "vars_hint": "MACOS_ARM64_RUNNER"
    },
    "sdk-distribution": {
      "enabled": true,
      "runner": "[\"self-hosted\",\"Linux\",\"X64\"]",
      "labels": { "os": "linux", "arch": "x64", "mode": "package-candidate" },
      "capabilities": { "dotnet": true, "syft": true, "glibc_2_35": true },
      "vars_hint": "SDK_DISTRIBUTION_RUNNER"
    },
    "debug-symbols": {
      "enabled": true,
      "runner": "[\"self-hosted\",\"Linux\",\"X64\"]",
      "labels": { "os": "linux", "arch": "x64", "mode": "release-candidate" },
      "capabilities": { "binutils": true, "syft": true },
      "vars_hint": "DEBUG_SYMBOLS_RUNNER"
    }
  },
  "deprecated_platforms": {
    "windows": "Support deferred. Restore from git history if needed.",
    "macos-x64": "Not supported; v3.6 macOS candidate is ARM64 only."
  }
}
